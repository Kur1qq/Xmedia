// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider     = "prisma-client-js"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @db.VarChar(100)
  email        String   @unique @db.VarChar(255)
  phone        String?  @db.VarChar(20)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  bookings Booking[]

  @@map("users")
}

enum EquipmentType {
  camera
  lighting
  accessories
  audio
  computer
  drone
  background
}

model Equipment {
  id          Int           @id @default(autoincrement())
  name        String        @db.VarChar(200)
  description String?       @db.Text
  type        EquipmentType @default(camera)
  images      String?       @db.Text
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  studios  StudioEquipment[]
  services ServiceEquipment[]

  @@map("equipment")
}

model Studio {
  id                Int      @id @default(autoincrement())
  name              String   @db.VarChar(200)
  description       String?  @db.Text
  address           String?  @db.VarChar(500)
  sizeSqm           Decimal? @map("size_sqm") @db.Decimal(10, 2)
  capacity          Int?
  hourlyRate        Decimal  @map("hourly_rate") @db.Decimal(12, 2)
  dailyRate         Decimal? @map("daily_rate") @db.Decimal(12, 2)
  equipmentIncluded Int?     @map("equipment_included")
  amenities         String?  @db.Text // JSON array as string
  images            String?  @db.Text // JSON array as string
  isAvailable       Boolean  @default(true) @map("is_available")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  equipment    StudioEquipment[]
  bookingItems BookingItem[]

  @@map("studios")
}

model StudioEquipment {
  id          Int      @id @default(autoincrement())
  studioId    Int      @map("studio_id")
  equipmentId Int      @map("equipment_id")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  studio    Studio    @relation(fields: [studioId], references: [id], onDelete: Cascade)
  equipment Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@map("studio_equipment")
}

// Үйлчилгээний ерөнхий бүлэг (Жишээ нь: "Зураглаач", "Зурагчин", "Дрон", "Эдит")
model ServiceCategory {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(100)
  description String?  @db.Text
  icon        String?  @db.VarChar(100)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  subCategories ServiceSubCategory[] // Дэд категориудтай холбогдох
  services      Service[] // Шууд үйлчилгээнүүдтэй холбогдох (хэрэв дэд категоригүй бол)

  @@map("service_categories")
}

// Дэд бүлэг (Жишээ нь: "Эдит" дотор-> "Фото", "Видео")
model ServiceSubCategory {
  id          Int      @id @default(autoincrement())
  categoryId  Int      @map("category_id")
  name        String   @db.VarChar(100)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  category ServiceCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  services Service[]

  @@map("service_sub_categories")
}

// Тодорхой үйлчилгээнүүд болон ҮНЭ (Жишээ нь: "Лого", "Рийл 90 секунд")
model Service {
  id            Int  @id @default(autoincrement())
  categoryId    Int  @map("category_id")
  subCategoryId Int? @map("sub_category_id") // Дэд категори байвал холбоно, үгүй бол NULL байна

  name        String  @db.VarChar(200) // "Лого", "Зураг янзлах", "Рийл 90 секунд"
  description String? @db.Text

  // Үнийн мэдээлэл
  price     Decimal @db.Decimal(12, 2) // 440000, 110000 г.м
  priceUnit String  @default("1ш") // "1ш", "1 цаг", "1 төсөл"

  // Үйлчилгээний нэмэлт мэдээлэл
  durationMinutes Int?    @map("duration_minutes")
  portfolioImages String? @db.Text
  isActive        Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  // Relations
  category     ServiceCategory     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  subCategory  ServiceSubCategory? @relation(fields: [subCategoryId], references: [id], onDelete: SetNull)
  equipments   ServiceEquipment[]
  bookingItems BookingItem[]

  @@map("services")
}

// Үйлчилгээнд багтах тоног төхөөрөмжүүд
model ServiceEquipment {
  id          Int @id @default(autoincrement())
  serviceId   Int @map("service_id")
  equipmentId Int @map("equipment_id")
  quantity    Int @default(1) // Тухайн үйлчилгээнд хэдэн ширхэг орох (жишээ нь: 2 гэрэл)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  // Relations
  service   Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  equipment Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@map("service_equipment")
}

// Захиалгын төлөв ба төлбөр
enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}

// Юу захиалж байгаа вэ? 
enum ItemType {
  STUDIO
  SERVICE
}

// 1. Үндсэн Захиалга
model Booking {
  id     Int @id @default(autoincrement())
  userId Int @map("user_id")

  totalAmount   Decimal       @map("total_amount") @db.Decimal(12, 2)
  status        BookingStatus @default(PENDING)
  paymentStatus PaymentStatus @default(UNPAID) @map("payment_status")
  notes         String?       @db.Text

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  // Relations
  user     User          @relation(fields: [userId], references: [id])
  items    BookingItem[]
  payments Payment[] // Захиалгад төлсөн төлбөрүүд

  @@map("bookings")
}

// 2. Захиалга доторх зүйлс 
model BookingItem {
  id        Int      @id @default(autoincrement())
  bookingId Int      @map("booking_id")
  itemType  ItemType

  // Сонгох боломжтой зүйлс: Аль нэг нь л утгатай байна
  studioId  Int? @map("studio_id")
  serviceId Int? @map("service_id")

  quantity   Int     @default(1)
  unitPrice  Decimal @map("unit_price") @db.Decimal(12, 2)
  totalPrice Decimal @map("total_price") @db.Decimal(12, 2)

  // Хуваарь:
  // Бүх үйлчилгээ болон студид "Өдөр" сонгох шаардлагатай
  bookingDate DateTime @map("booking_date") @db.Date

  // Цаг сонгох: Студи, Шууд дамжуулалт, Зураглаачид НАРТ цаг шаардлагатай (12:00-14:00)
  // харин 'Эдит' үйлчилгээнд зөвхөн bookingDate байхад хангалттай тул эдгээр нь NULL үлдэж болно.
  startTime DateTime? @map("start_time") @db.Time(0)
  endTime   DateTime? @map("end_time") @db.Time(0)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  // Relations
  booking Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  studio  Studio?  @relation(fields: [studioId], references: [id], onDelete: SetNull)
  service Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@map("booking_items")
}

// --------------------------------------------------------------------------
// ТӨЛБӨР ТООЦОО (QPAY)
// --------------------------------------------------------------------------

model Payment {
  id        Int @id @default(autoincrement())
  bookingId Int @map("booking_id")

  // QPay-ээс буцаж ирэх утгууд
  invoiceId  String  @unique @map("invoice_id") @db.VarChar(255) // QPay дээр үүссэн нэхэмжлэхийн ID
  qpayQrText String? @map("qpay_qr_text") @db.Text // QR код үүсгэх текст
  qpayUrls   String? @map("qpay_urls") @db.Text // Банкны аппликейшнүүдийн deep link (JSON)

  // Төлбөрийн мэдээлэл
  amount Decimal       @db.Decimal(12, 2)
  status PaymentStatus @default(UNPAID)

  // Төлсөн үеийн мэдээлэл
  paidAt        DateTime? @map("paid_at") @db.Timestamp(0) // Хэзээ төлбөр төлөгдсөн
  transactionId String?   @map("transaction_id") @db.VarChar(255) // QPay эсвэл банкны гүйлгээний дугаар

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  // Relations
  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("payments")
}
