// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @db.VarChar(100)
  email        String   @unique @db.VarChar(255)
  phone        String?  @db.VarChar(20)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  bookings Booking[]

  @@map("users")
}

enum EquipmentType {
  camera
  lighting
  accessories
  audio
  computer
  drone
  background
}

model Equipment {
  id          Int           @id @default(autoincrement())
  name        String        @db.VarChar(200)
  description String?       @db.Text
  type        EquipmentType @default(camera)
  images      Json? // FIX: was @db.Text, now proper JSON
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  studios              StudioEquipment[]
  services             ServiceEquipment[]
  liveServices         LiveServiceEquipment[]
  photographerServices PhotographerServiceEquipment[]
  bundleServices       BundleServiceEquipment[]

  @@map("equipment")
}

model Studio {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(200)
  description String?  @db.Text
  address     String?  @db.VarChar(500)
  sizeSqm     Decimal? @map("size_sqm") @db.Decimal(10, 2)
  capacity    Int?
  // FIX: equipmentIncluded Int? removed — StudioEquipment join table handles this
  amenities   Json? // FIX: was @db.Text, now proper JSON
  images      Json? // FIX: was @db.Text, now proper JSON
  isAvailable Boolean  @default(true) @map("is_available")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  equipment    StudioEquipment[]
  bookingItems BookingItem[]
  packages     StudioPackage[]

  @@map("studios")
}

// Студийн үнийн багцууд (Жишээ нь: 3 цаг 440,000₮, 6 цаг 660,000₮)
model StudioPackage {
  id       Int     @id @default(autoincrement())
  studioId Int     @map("studio_id")
  hours    Int
  price    Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  studio Studio @relation(fields: [studioId], references: [id], onDelete: Cascade)

  @@index([studioId])
  @@map("studio_packages")
}

model StudioEquipment {
  id          Int      @id @default(autoincrement())
  studioId    Int      @map("studio_id")
  equipmentId Int      @map("equipment_id")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  studio    Studio    @relation(fields: [studioId], references: [id], onDelete: Cascade)
  equipment Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@unique([studioId, equipmentId]) // FIX: prevent duplicate equipment on same studio
  @@map("studio_equipment")
}

// Үйлчилгээний ерөнхий бүлэг (Жишээ нь: "Зураглаач", "Зурагчин", "Дрон", "Эдит")
model ServiceCategory {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(100)
  description String?  @db.Text
  icon        String?  @db.VarChar(100)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  subCategories        ServiceSubCategory[]
  services             Service[]
  liveServices         LiveService[]
  photographerServices PhotographerService[]
  editServices         EditService[]

  @@map("service_categories")
}

// Дэд бүлэг (Жишээ нь: "Эдит" дотор-> "Фото", "Видео")
model ServiceSubCategory {
  id          Int      @id @default(autoincrement())
  categoryId  Int      @map("category_id")
  name        String   @db.VarChar(100)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  category ServiceCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  services Service[]

  @@map("service_sub_categories")
}

// Тодорхой үйлчилгээнүүд болон ҮНЭ (Жишээ нь: "Лого", "Рийл 90 секунд")
model Service {
  id            Int  @id @default(autoincrement())
  categoryId    Int  @map("category_id")
  subCategoryId Int? @map("sub_category_id") // Дэд категори байвал холбоно, үгүй бол NULL байна

  name        String  @db.VarChar(200) // "Лого", "Зураг янзлах", "Рийл 90 секунд"
  description String? @db.Text

  // Үнийн мэдээлэл
  price     Decimal @db.Decimal(12, 2) // 440000, 110000 г.м
  priceUnit String  @default("1ш") // "1ш", "1 цаг", "1 төсөл"

  // Үйлчилгээний нэмэлт мэдээлэл
  durationMinutes Int?    @map("duration_minutes")
  portfolioImages String? @db.Text
  isActive        Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  // Relations
  category     ServiceCategory     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  subCategory  ServiceSubCategory? @relation(fields: [subCategoryId], references: [id], onDelete: SetNull)
  equipments   ServiceEquipment[]
  bookingItems BookingItem[]

  @@map("services")
}

// --------------------------------------------------------------------------
// ШУУД ДАМЖУУЛАЛТ (LIVE STREAMING SERVICES)
// --------------------------------------------------------------------------

// Шууд дамжуулалтын үйлчилгээ (камерийн тоогоор үнэлдэг)
model LiveService {
  id          Int     @id @default(autoincrement())
  categoryId  Int     @map("category_id")
  name        String  @db.VarChar(200)
  description String? @db.Text
  image       String? @db.Text
  amenities   Json?
  isActive    Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  category     ServiceCategory         @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  priceTiers   LiveServiceCameraTier[]
  equipments   LiveServiceEquipment[]
  bookingItems BookingItem[] // FIX: back-relation

  @@map("live_services")
}

// камерийн тоогоор тогтоосон үнийн мэдээлэл
model LiveServiceCameraTier {
  id            Int     @id @default(autoincrement())
  liveServiceId Int     @map("live_service_id")
  cameraCount   Int     @map("camera_count") // 1, 2, 3 ...
  label         String? @db.VarChar(200) // "1 камер", "2 камер" г.м.
  price         Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  liveService LiveService @relation(fields: [liveServiceId], references: [id], onDelete: Cascade)

  @@map("live_service_camera_tiers")
}

// Шууд дамжуулалтын үйлчилгээнд ашиглагдах тоног төхөөрөмжүүд
model LiveServiceEquipment {
  id            Int @id @default(autoincrement())
  liveServiceId Int @map("live_service_id")
  equipmentId   Int @map("equipment_id")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  liveService LiveService @relation(fields: [liveServiceId], references: [id], onDelete: Cascade)
  equipment   Equipment   @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@unique([liveServiceId, equipmentId]) // FIX: no duplicate equipment per live service
  @@map("live_service_equipment")
}

// --------------------------------------------------------------------------
// ЗУРАГЛААЧ (PHOTOGRAPHER SERVICES)
// --------------------------------------------------------------------------

// Үндсэн үйлчилгээний төрөл (Зураглаач, Зурагчин, Дрон...) - Админ тохируулна
model PhotographerMainType {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(100) // "Зураглаач", "Зурагчин", "Дрон"
  description String?  @db.Text
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  subTypes PhotographerSubType[]
  services PhotographerService[]

  @@map("photographer_main_types")
}

// Дэд үйлчилгээний төрөл (Рийл, Богино контент, Фото, Батарей...) - Админ тохируулна
model PhotographerSubType {
  id          Int      @id @default(autoincrement())
  mainTypeId  Int      @map("main_type_id")
  name        String   @db.VarChar(100) // "Рийл", "Богино контент", "Фото", "Батарей"
  description String?  @db.Text
  price       Decimal? @db.Decimal(12, 2)
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  mainType PhotographerMainType         @relation(fields: [mainTypeId], references: [id], onDelete: Cascade)
  services PhotographerService[]
  packages PhotographerServicePackage[]

  @@map("photographer_sub_types")
}

// Зураглаачийн үйлчилгээний дэд төрлөөс хамаарсан үнийн багцууд
model PhotographerServicePackage {
  id                    Int     @id @default(autoincrement())
  photographerServiceId Int     @map("photographer_service_id")
  subTypeId             Int     @map("sub_type_id")
  price                 Decimal @db.Decimal(12, 2)
  duration              Int     @default(1)

  // Optional name if you want to override subType name
  priceLabel String? @db.VarChar(200)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  photographerService PhotographerService @relation(fields: [photographerServiceId], references: [id], onDelete: Cascade)
  subType             PhotographerSubType @relation(fields: [subTypeId], references: [id], onDelete: Cascade)

  @@index([photographerServiceId])
  @@index([subTypeId])
  @@map("photographer_service_packages")
}

// Зураглаачийн үйлчилгээ
model PhotographerService {
  id         Int @id @default(autoincrement())
  categoryId Int @map("category_id")
  mainTypeId Int @map("main_type_id")

  name        String  @db.VarChar(200)
  description String? @db.Text
  image       String? @db.Text
  amenities   Json?
  isActive    Boolean @default(true) @map("is_active")
  sortOrder   Int     @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  category              ServiceCategory                @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  mainType              PhotographerMainType           @relation(fields: [mainTypeId], references: [id])
  packages              PhotographerServicePackage[]
  equipments            PhotographerServiceEquipment[]
  bookingItems          BookingItem[] // FIX: back-relation
  photographerSubType   PhotographerSubType?           @relation(fields: [photographerSubTypeId], references: [id])
  photographerSubTypeId Int?

  @@index([mainTypeId]) // FIX: index
  @@map("photographer_services")
}

// Зураглаачийн үйлчилгээнд ашиглагдах тоног төхөөрөмжүүд
model PhotographerServiceEquipment {
  id                    Int @id @default(autoincrement())
  photographerServiceId Int @map("photographer_service_id")
  equipmentId           Int @map("equipment_id")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  photographerService PhotographerService @relation(fields: [photographerServiceId], references: [id], onDelete: Cascade)
  equipment           Equipment           @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@unique([photographerServiceId, equipmentId]) // FIX: no duplicate equipment per service
  @@map("photographer_service_equipment")
}

// Үйлчилгээнд багтах тоног төхөөрөмжүүд
model ServiceEquipment {
  id          Int @id @default(autoincrement())
  serviceId   Int @map("service_id")
  equipmentId Int @map("equipment_id")
  quantity    Int @default(1)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  service   Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  equipment Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@unique([serviceId, equipmentId]) // FIX: no duplicate equipment per service
  @@map("service_equipment")
}

// Захиалгын төлөв ба төлбөр
enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}

// Юу захиалж байгаа вэ?
enum ItemType {
  STUDIO
  SERVICE
  PHOTOGRAPHER_SERVICE // FIX: Зураглаачийн үйлчилгээ
  EDIT_SERVICE // FIX: Эдит үйлчилгээ
  LIVE_SERVICE // FIX: Шууд дамжуулалтын үйлчилгээ
  BUNDLE_SERVICE // Багц үйлчилгээ
}

// 1. Үндсэн Захиалга
model Booking {
  id     Int @id @default(autoincrement())
  userId Int @map("user_id")

  totalAmount   Decimal       @map("total_amount") @db.Decimal(12, 2)
  status        BookingStatus @default(PENDING)
  paymentStatus PaymentStatus @default(UNPAID) @map("payment_status")
  notes         String?       @db.Text

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  // Relations
  user     User          @relation(fields: [userId], references: [id])
  items    BookingItem[]
  payments Payment[]

  @@index([userId]) // FIX: fast user→bookings lookup
  @@map("bookings")
}

// 2. Захиалга доторх зүйлс
model BookingItem {
  id        Int      @id @default(autoincrement())
  bookingId Int      @map("booking_id")
  itemType  ItemType

  // FIX: Аль нэг нь л утгатай байна — itemType-р ялгана
  studioId              Int? @map("studio_id")
  serviceId             Int? @map("service_id")
  photographerServiceId Int? @map("photographer_service_id") // FIX: нэмсэн
  editServiceId         Int? @map("edit_service_id") // FIX: нэмсэн
  liveServiceId         Int? @map("live_service_id") // FIX: нэмсэн
  bundleServiceId       Int? @map("bundle_service_id") // Багц үйлчилгээ

  quantity   Int     @default(1)
  unitPrice  Decimal @map("unit_price") @db.Decimal(12, 2)
  totalPrice Decimal @map("total_price") @db.Decimal(12, 2)

  // Бүх үйлчилгээ болон студид өдөр сонгох шаардлагатай
  bookingDate String   @map("booking_date") @db.VarChar(10)

  // Цаг: Студи, Шууд дамжуулалт, Зураглаачид шаардлагатай; Эдитэд биш.
  startTime String?   @map("start_time") @db.VarChar(8)
  endTime   String?   @map("end_time") @db.VarChar(8)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  // Relations
  booking             Booking              @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  studio              Studio?              @relation(fields: [studioId], references: [id], onDelete: SetNull)
  service             Service?             @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  photographerService PhotographerService? @relation(fields: [photographerServiceId], references: [id], onDelete: SetNull) // FIX
  editService         EditService?         @relation(fields: [editServiceId], references: [id], onDelete: SetNull) // FIX
  liveService         LiveService?         @relation(fields: [liveServiceId], references: [id], onDelete: SetNull) // FIX
  bundleService       BundleService?       @relation(fields: [bundleServiceId], references: [id], onDelete: SetNull)

  @@index([bookingId]) // FIX: index for fast booking→items lookup
  @@map("booking_items")
}

// --------------------------------------------------------------------------
// ТӨЛБӨР ТООЦОО (QPAY)
// --------------------------------------------------------------------------

model Payment {
  id        Int @id @default(autoincrement())
  bookingId Int @map("booking_id")

  // QPay-ээс буцаж ирэх утгууд
  invoiceId  String  @unique @map("invoice_id") @db.VarChar(255) // QPay дээр үүссэн нэхэмжлэхийн ID
  qpayQrText String? @map("qpay_qr_text") @db.Text // QR код үүсгэх текст
  qpayUrls   String? @map("qpay_urls") @db.Text // Банкны аппликейшнүүдийн deep link (JSON)

  // Төлбөрийн мэдээлэл
  amount Decimal       @db.Decimal(12, 2)
  status PaymentStatus @default(UNPAID)

  // Төлсөн үеийн мэдээлэл
  paidAt        DateTime? @map("paid_at") @db.Timestamp(0) // Хэзээ төлбөр төлөгдсөн
  transactionId String?   @map("transaction_id") @db.VarChar(255) // QPay эсвэл банкны гүйлгээний дугаар

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  // Relations
  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("payments")
}

// --------------------------------------------------------------------------
// ЭДИТ ҮЙЛЧИЛГЭЭ (EDIT SERVICES)
// --------------------------------------------------------------------------

model EditMainType {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(100)
  description String?  @db.Text
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  subTypes EditSubType[]
  services EditService[]

  @@map("edit_main_types")
}

model EditSubType {
  id          Int      @id @default(autoincrement())
  mainTypeId  Int      @map("main_type_id")
  name        String   @db.VarChar(100)
  description String?  @db.Text
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  mainType EditMainType  @relation(fields: [mainTypeId], references: [id], onDelete: Cascade)
  services EditService[]
  packages EditServicePackage[]

  @@map("edit_sub_types")
}

// Эдит үйлчилгээний дэд төрлөөс хамаарсан үнийн багцууд
model EditServicePackage {
  id            Int     @id @default(autoincrement())
  editServiceId Int     @map("edit_service_id")
  subTypeId     Int     @map("sub_type_id")
  price         Decimal @db.Decimal(12, 2)

  // Optional name if you want to override subType name
  priceLabel String? @db.VarChar(200)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  editService EditService  @relation(fields: [editServiceId], references: [id], onDelete: Cascade)
  subType     EditSubType  @relation(fields: [subTypeId], references: [id], onDelete: Cascade)

  @@index([editServiceId])
  @@index([subTypeId])
  @@map("edit_service_packages")
}

model EditService {
  id          Int     @id @default(autoincrement())
  categoryId  Int     @map("category_id")
  mainTypeId  Int     @map("main_type_id")
  subTypeId   Int?    @map("sub_type_id")
  name        String  @db.VarChar(200)
  description String? @db.Text
  image       String? @db.Text
  amenities   Json?
  isActive    Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  category     ServiceCategory      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  mainType     EditMainType         @relation(fields: [mainTypeId], references: [id])
  subType      EditSubType?         @relation(fields: [subTypeId], references: [id], onDelete: SetNull)
  packages     EditServicePackage[]
  bookingItems BookingItem[] // FIX: back-relation

  @@index([mainTypeId]) // FIX: index
  @@map("edit_services")
}

// --------------------------------------------------------------------------
// БАГЦ ҮЙЛЧИЛГЭЭ (BUNDLE SERVICES)
// --------------------------------------------------------------------------

model BundleService {
  id               Int      @id @default(autoincrement())
  name             String   @db.VarChar(200)
  description      String?  @db.Text
  price            Decimal  @db.Decimal(12, 2)
  image            String?  @db.Text
  includedServices Json?    // Array of strings indicating what services are included
  amenities        Json?    // Array of strings for "advantages" (давуу тал)
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  equipments       BundleServiceEquipment[]
  bookingItems     BookingItem[]
  
  @@map("bundle_services")
}

model BundleServiceEquipment {
  id              Int @id @default(autoincrement())
  bundleServiceId Int @map("bundle_service_id")
  equipmentId     Int @map("equipment_id")
  quantity        Int @default(1)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  bundleService BundleService @relation(fields: [bundleServiceId], references: [id], onDelete: Cascade)
  equipment     Equipment     @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@unique([bundleServiceId, equipmentId])
  @@map("bundle_service_equipment")
}

// --------------------------------------------------------------------------
// ADMIN AUTH & LOGGING
// --------------------------------------------------------------------------

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  MODERATOR
  EDITOR
  CUSTOM
}

model Admin {
  id           Int       @id @default(autoincrement())
  username     String    @unique @db.VarChar(100)
  password     String    @db.VarChar(255)
  image        String?   @db.Text
  role         AdminRole @default(ADMIN)
  customRoleId Int?      @map("custom_role_id")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  logs       AdminLog[]
  customRole AdminPermissionRole? @relation(fields: [customRoleId], references: [id], onDelete: SetNull)

  @@map("admins")
}

model AdminPermissionRole {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(100)
  permissions Json     // Array of allowed route paths, e.g., ["/", "/users", "/bookings"]
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  admins Admin[]

  @@map("admin_permission_roles")
}

model AdminLog {
  id        Int      @id @default(autoincrement())
  adminId   Int?     @map("admin_id") // FIX: nullable — admin устгасан ч лог хадгалагдана
  action    String   @db.VarChar(200)
  entity    String?  @db.VarChar(100)
  entityId  Int?     @map("entity_id")
  detail    String?  @db.Text
  ip        String?  @db.VarChar(45)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  admin Admin? @relation(fields: [adminId], references: [id], onDelete: SetNull) // FIX: SetNull

  @@map("admin_logs")
}

model AdminNotification {
  id          Int      @id @default(autoincrement())
  type        String   @db.VarChar(50)  // e.g. "ORDER_CANCELLED"
  message     String   @db.Text
  isRead      Boolean  @default(false) @map("is_read")
  referenceId Int?     @map("reference_id") // ID of the booking
  
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  @@map("admin_notifications")
}

// --------------------------------------------------------------------------
// PORTFOLIO (ӨМНӨХ АЖЛУУДЫН УДИРДЛАГА)
// --------------------------------------------------------------------------

enum PortfolioServiceType {
  STUDIO
  LIVE
  PHOTOGRAPHER
  PHOTO_EDIT
  VIDEO_EDIT
}

model PortfolioItem {
  id          Int                  @id @default(autoincrement())
  serviceType PortfolioServiceType @map("service_type")
  title       String               @db.VarChar(200)
  description String?              @db.Text
  images      Json                 // string[] — нэг буюу хэд хэдэн зурагны URL
  tags        Json?                // string[] — optional tag/label
  isPublished Boolean              @default(true) @map("is_published")
  sortOrder   Int                  @default(0) @map("sort_order")

  // LIVE-specific fields
  liveDate    DateTime? @map("live_date") @db.Timestamp(0)
  viewCount   Int?      @map("view_count")
  youtubeUrl  String?   @map("youtube_url") @db.VarChar(500)
  facebookUrl String?   @map("facebook_url") @db.VarChar(500)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  @@index([serviceType])
  @@map("portfolio_items")
}

// --------------------------------------------------------------------------
// ДЭЛГЭРЭНГҮЙ НҮҮР ХУУДАС (HERO SLIDES)
// --------------------------------------------------------------------------

model HeroSlide {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(255)
  highlight   String?  @db.VarChar(255)
  subTitle    String?  @db.VarChar(255)
  description String?  @db.Text
  image       String   @db.Text
  order       Int      @default(0)
  isActive    Boolean  @default(true) @map("is_active")
  
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  @@map("hero_slides")
}
